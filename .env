VUS_MAX_ENV=1
SCENARIO_RAMP_STAGE_NUMBER_ENV=5
TARGET_ENV=dev
USE_INTERNAL_ACCESS_ENV=true
SCRIPT_ENV=test
REQ_DUMP=false
ENABLE_FILE_WRITING=true
MAX_AVAILABLE_TEST_ENTITIES_ENV=1
SCENARIO_TYPE_ENV=rampingArrivalRate,constantArrivalRate
SCENARIO_PER_VU_RAMPING_SIZE=true
SCENARIO_PER_VU_SINGLE_ITERATION_ENV=true
SCENARIO_PER_VU_EXECUTIONS_ENV=2
SCENARIO_DURATION_ENV=1
SCENARIO_TIME_UNIT_ENV=1
SCENARIO_RAMP_GROWING_RAMP_BUILDING_VU_POOL=15
THRESHOLDS_API_MAX_AVG_MS_ENV=300
THRESHOLDS_API_MAX_P90_MS_ENV=600
THRESHOLDS_API_MAX_P95_MS_ENV=900
THRESHOLDS_API_MAX_FAILED_REQ_RATE_ENV=0.02
RESULTS_DIR=/tmp
SECRETS_FILE_PATH=/client.env
